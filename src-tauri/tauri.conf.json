{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HomeworkHelper",
  "version": "0.1.0",
  "identifier": "com.lsh930309.homeworkhelper",
  "build": {
    "beforeDevCommand": "cd src/gui/new_gui/frontend && npm run dev",
    "beforeBuildCommand": "cd src/gui/new_gui/frontend && npm run build",
    "devUrl": "http://127.0.0.1:1430",
    "frontendDist": "../build/main-gui-static"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "숙제 관리자",
        "width": 520,
        "height": 360,
        "minWidth": 500,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "center": true,
        "visible": true,
        "decorations": false,
        "alwaysOnTop": false,
        "backgroundColor": "#0b1120",
        "zoomHotkeysEnabled": false
      },
      {
        "label": "sidebar",
        "title": "HomeworkHelper 사이드바",
        "width": 348,
        "height": 640,
        "minWidth": 348,
        "minHeight": 360,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "backgroundColor": "#00000000",
        "zoomHotkeysEnabled": false
      },
      {
        "label": "settings-general",
        "title": "설정 · 일반",
        "width": 620,
        "height": 420,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": false,
        "backgroundColor": "#0b1120",
        "zoomHotkeysEnabled": false
      },
      {
        "label": "settings-notify",
        "title": "설정 · 알림",
        "width": 680,
        "height": 560,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": false,
        "backgroundColor": "#0b1120",
        "zoomHotkeysEnabled": false
      },
      {
        "label": "settings-sidebar",
        "title": "설정 · 사이드바",
        "width": 680,
        "height": 640,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": false,
        "backgroundColor": "#0b1120",
        "zoomHotkeysEnabled": false
      },
      {
        "label": "settings-screenshot",
        "title": "설정 · 스크린샷",
        "width": 680,
        "height": 620,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": false,
        "backgroundColor": "#0b1120",
        "zoomHotkeysEnabled": false
      },
      {
        "label": "settings-recording",
        "title": "설정 · OBS 녹화",
        "width": 680,
        "height": 620,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": false,
        "backgroundColor": "#0b1120",
        "zoomHotkeysEnabled": false
      },
      {
        "label": "settings-hoyolab",
        "title": "설정 · HoYoLab",
        "width": 720,
        "height": 660,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": false,
        "backgroundColor": "#0b1120",
        "zoomHotkeysEnabled": false
      },
      {
        "label": "process-editor",
        "title": "게임 편집",
        "width": 680,
        "height": 620,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": false,
        "backgroundColor": "#0b1120",
        "zoomHotkeysEnabled": false
      },
      {
        "label": "shortcut-editor",
        "title": "웹 바로가기 편집",
        "width": 620,
        "height": 360,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": false,
        "backgroundColor": "#0b1120",
        "zoomHotkeysEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:8000; img-src 'self' asset: http://asset.localhost blob: data: https://github.githubassets.com; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' asset: http://asset.localhost; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": [
      "../assets/icons/app/app_icon.ico"
    ],
    "resources": {
      "../assets/fonts/NEXONLv1GothicOTFBold.otf": "assets/fonts/NEXONLv1GothicOTFBold.otf"
    }
  }
}
